{
  "name": "@agentic/node",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "agentic-node",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "vitest run"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "vitest": "^2.1.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
