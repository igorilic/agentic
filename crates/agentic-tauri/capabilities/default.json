{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the Agentic Tauri shell. Grants the main window access to core commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-subscribe-events",
    "allow-get-event-history",
    "allow-start-scripted-run",
    "allow-cancel-run",
    "allow-chat-send-message",
    "allow-chat-list-messages",
    "allow-mention-agent",
    "allow-triage-finding"
  ]
}
